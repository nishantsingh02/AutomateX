# ============================================
# AutomateX Backend — Environment Variables
# ============================================

# MongoDB connection URI
# For local development: mongodb://localhost:27017/automatex
# For Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/AutomateX?retryWrites=true&w=majority&appName=Cluster0
MONGO_URL="mongodb://localhost:27017/automatex"

# JWT signing secret — CHANGE THIS in production (use a strong random string, e.g. `openssl rand -hex 32`)
JWT_SECERTE="change-me-to-a-strong-random-string"

# Port the Express server listens on
PORT=3000
